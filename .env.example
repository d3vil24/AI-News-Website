# Supabase — get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key

# Admin protection — used to protect /api/admin-action, /api/publish, /api/run-ingestion
# Set a strong random string, e.g.: openssl rand -hex 20
# NEXT_PUBLIC_ prefix allows the admin-review UI to send it in request headers
NEXT_PUBLIC_ADMIN_TOKEN=your-secret-admin-token

# Optional: public site URL for sitemap/OG tags
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
